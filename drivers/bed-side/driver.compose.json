      "title": {
        "en": "Side power"
      }
    }
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "cloud"
  ],
  "images": {
    "small": "/drivers/bed-side/assets/images/small.png",
    "large": "/drivers/bed-side/assets/images/large.png",
    "xlarge": "/drivers/bed-side/assets/images/xlarge.png"
  },
  "pair": [
    {
      "id": "login_credentials",
      "template": "login_credentials",
      "options": {
        "usernameLabel": {
          "en": "Email"
        },
        "usernamePlaceholder": "you@example.com",
        "passwordLabel": {
          "en": "Password"
        }
      },
      "navigation": {
        "next": "list_devices"
      }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "repair": [
    {
      "id": "login_credentials",
      "template": "login_credentials",
      "options": {
        "usernameLabel": {
          "en": "Email"
        },
        "usernamePlaceholder": "you@example.com",
        "passwordLabel": {
          "en": "Password"
        }
      }
    }
  ],
  "settings": [
    {
      "id": "poll_interval",
      "type": "number",
      "label": {
        "en": "Refresh interval (minutes)"
      },
      "value": 5,
      "min": 1,
      "max": 60,
      "hint": {
        "en": "How often to read the bed side's state from Eight Sleep."
      }
    }
  ]
