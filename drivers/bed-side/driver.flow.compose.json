{
  "triggers": [
    {
      "id": "presence_started",
      "title": {
        "en": "Someone got into the bed"
      },
      "tokens": [
        { "name": "bed_temperature", "type": "number", "title": { "en": "Bed temperature" }, "example": 30 },
        { "name": "target_temperature", "type": "number", "title": { "en": "Target temperature" }, "example": 21 }
      ]
    },
    {
      "id": "presence_stopped",
      "title": {
        "en": "The bed became empty"
      }
    },
    {
      "id": "sleep_session_ended",
      "title": {
        "en": "A sleep session ended"
      },
      "tokens": [
        { "name": "hours_slept", "type": "number", "title": { "en": "Hours slept" }, "example": 7.5 },
        { "name": "fitness_score", "type": "number", "title": { "en": "Sleep fitness score" }, "example": 82 },
        { "name": "quality_score", "type": "number", "title": { "en": "Sleep quality score" }, "example": 90 },
        { "name": "routine_score", "type": "number", "title": { "en": "Sleep routine score" }, "example": 75 }
      ]
    },
    {
      "id": "sleep_stage_changed",
      "title": {
        "en": "Sleep stage changed"
      },
      "hint": {
        "en": "Fires when the detected sleep stage changes (e.g. light, deep, rem)."
      },
      "tokens": [
        {
          "name": "stage",
          "type": "string",
          "title": {
            "en": "Stage"
          },
          "example": "deep"
        },
        {
          "name": "previous_stage",
          "type": "string",
          "title": {
            "en": "Previous stage"
          },
          "example": "light"
        }
      ]
    },
    {
      "id": "alarm_ringing",
      "title": {
        "en": "The alarm started ringing"
      },
      "tokens": [
        { "name": "time", "type": "string", "title": { "en": "Alarm time" }, "example": "07:00:00" }
      ]
    },
    {
      "id": "alarm_dismissed",
      "title": {
        "en": "The alarm stopped"
      }
    },
    {
      "id": "snore_mitigation_started",
      "title": {
        "en": "Snore mitigation started"
      }
    },
    {
      "id": "snore_mitigation_stopped",
      "title": {
        "en": "Snore mitigation stopped"
      }
    },
    {
      "id": "water_became_low",
      "title": {
        "en": "Water became low"
      }
    },
    {
      "id": "water_refilled",
      "title": {
        "en": "Water was refilled"
      }
    },
    {
      "id": "priming_started",
      "title": {
        "en": "Priming started"
      }
    },
    {
      "id": "priming_finished",
      "title": {
        "en": "Priming finished"
      }
    },
    {
      "id": "weekly_summary",
      "title": {
        "en": "Daily sleep summary is ready"
      },
      "hint": {
        "en": "Fires once per day with 7-day rolling averages of your sleep scores."
      },
      "tokens": [
        { "name": "avg_fitness", "type": "number", "title": { "en": "Avg fitness score" }, "example": 80 },
        { "name": "avg_quality", "type": "number", "title": { "en": "Avg quality score" }, "example": 85 },
        { "name": "avg_routine", "type": "number", "title": { "en": "Avg routine score" }, "example": 75 },
        { "name": "avg_hours", "type": "number", "title": { "en": "Avg hours slept" }, "example": 7.4 }
      ]
    }
  ],
  "conditions": [
    {
      "id": "is_present",
      "title": {
        "en": "Someone !{{is|isn't}} in the bed"
      }
    },
    {
      "id": "side_is_on",
      "title": {
        "en": "The side !{{is|isn't}} on"
      }
    },
    {
      "id": "is_away",
      "title": {
        "en": "Away mode !{{is|isn't}} on"
      }
    }
  ],
  "actions": [
    {
      "id": "set_temperature",
      "title": {
        "en": "Set target temperature"
      },
      "titleFormatted": {
        "en": "Set target temperature to [[temperature]] °C"
      },
      "args": [
        {
          "name": "temperature",
          "type": "number",
          "min": 13,
          "max": 44,
          "step": 0.5,
          "title": {
            "en": "Temperature"
          },
          "label": {
            "en": "°C"
          }
        }
      ]
    },
    {
      "id": "turn_on",
      "title": {
        "en": "Turn the side on"
      }
    },
    {
      "id": "turn_off",
      "title": {
        "en": "Turn the side off"
      }
    },
    {
      "id": "snooze_alarm",
      "title": {
        "en": "Snooze the alarm"
      },
      "titleFormatted": {
        "en": "Snooze the alarm for [[minutes]] minutes"
      },
      "args": [
        {
          "name": "minutes",
          "type": "number",
          "min": 1,
          "max": 60,
          "step": 1,
          "title": {
            "en": "Minutes"
          },
          "label": {
            "en": "min"
          }
        }
      ]
    },
    {
      "id": "stop_alarm",
      "title": {
        "en": "Stop the alarm"
      }
    },
    {
      "id": "start_away",
      "title": {
        "en": "Start away mode"
      }
    },
    {
      "id": "stop_away",
      "title": {
        "en": "Stop away mode"
      }
    },
    {
      "id": "prime_pod",
      "title": {
        "en": "Prime the Pod"
      }
    },
    {
      "id": "set_base_preset",
      "title": {
        "en": "Set the base preset"
      },
      "titleFormatted": {
        "en": "Set the base to [[preset]]"
      },
      "args": [
        {
          "name": "preset",
          "type": "dropdown",
          "title": { "en": "Preset" },
          "values": [
            { "id": "sleep", "title": { "en": "Sleep" } },
            { "id": "relaxing", "title": { "en": "Relaxing" } },
            { "id": "reading", "title": { "en": "Reading" } },
            { "id": "flat", "title": { "en": "Flat" } }
          ]
        }
      ]
    },
    {
      "id": "set_head_angle",
      "title": {
        "en": "Set the head angle"
      },
      "titleFormatted": {
        "en": "Set the head angle to [[angle]]°"
      },
      "args": [
        { "name": "angle", "type": "number", "min": 0, "max": 45, "step": 1, "title": { "en": "Angle" } }
      ]
    },
    {
      "id": "set_feet_angle",
      "title": {
        "en": "Set the feet angle"
      },
      "titleFormatted": {
        "en": "Set the feet angle to [[angle]]°"
      },
      "args": [
        { "name": "angle", "type": "number", "min": 0, "max": 45, "step": 1, "title": { "en": "Angle" } }
      ]
    },
    {
      "id": "set_temperature_f",
      "title": {
        "en": "Set target temperature in Fahrenheit"
      },
      "hint": {
        "en": "Sets the side's target temperature using a Fahrenheit value."
      },
      "titleFormatted": {
        "en": "Set target temperature to [[fahrenheit]] °F"
      },
      "args": [
        { "name": "fahrenheit", "type": "number", "min": 55, "max": 110, "step": 1, "title": { "en": "Fahrenheit" } }
      ]
    },
    {
      "id": "set_temperature_in",
      "title": {
        "en": "Set target temperature after a delay"
      },
      "hint": {
        "en": "Waits the given number of minutes, then sets the target temperature."
      },
      "titleFormatted": {
        "en": "Set target temperature to [[temperature]] °C in [[minutes]] minutes"
      },
      "args": [
        { "name": "temperature", "type": "number", "min": 13, "max": 44, "step": 0.5, "title": { "en": "Temperature" } },
        { "name": "minutes", "type": "number", "min": 1, "max": 720, "step": 1, "title": { "en": "Minutes" } }
      ]
    },
    {
      "id": "set_one_off_alarm",
      "title": {
        "en": "Set a one-off alarm"
      },
      "hint": {
        "en": "Creates a single non-repeating alarm for this side at the given time."
      },
      "titleFormatted": {
        "en": "Set a one-off alarm at [[time]]"
      },
      "args": [
        {
          "name": "time",
          "type": "time",
          "title": {
            "en": "Time"
          }
        }
      ]
    }
  ]
}
