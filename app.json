        "button.alarm_stop": {
          "title": {
            "en": "Stop alarm"
          },
          "maintenanceAction": true
        },
        "target_temperature": {
          "title": {
            "en": "Target temperature"
          },
          "min": 13,
          "max": 44,
          "step": 0.5,
          "units": {
            "en": "°C"
          }
        },
        "measure_temperature": {
          "title": {
            "en": "Bed temperature"
          }
        },
        "measure_temperature.room": {
          "title": {
            "en": "Room temperature"
          }
        }
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "cloud"
      ],
      "images": {
        "small": "/drivers/bed-side/assets/images/small.png",
        "large": "/drivers/bed-side/assets/images/large.png",
        "xlarge": "/drivers/bed-side/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "login_credentials",
          "template": "login_credentials",
          "options": {
            "usernameLabel": {
              "en": "Email"
            },
            "usernamePlaceholder": "you@example.com",
            "passwordLabel": {
              "en": "Password"
            }
          },
          "navigation": {
            "next": "list_devices"
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "repair": [
        {
          "id": "login_credentials",
          "template": "login_credentials",
          "options": {
            "usernameLabel": {
              "en": "Email"
            },
            "usernamePlaceholder": "you@example.com",
            "passwordLabel": {
              "en": "Password"
            }
          }
        }
      ],
      "settings": [
        {
          "id": "poll_interval",
