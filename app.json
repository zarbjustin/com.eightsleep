{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.eightsleep",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "brandColor": "#0A1828",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Eight Sleep"
  },
  "description": {
    "en": "Monitor and control your Eight Sleep Pod from Homey — temperature, presence, sleep metrics and alarms, per bed side."
  },
  "category": [
    "climate"
  ],
  "tags": {
    "en": [
      "eight sleep",
      "pod",
      "mattress",
      "sleep",
      "bed",
      "temperature",
      "heart rate",
      "presence"
    ]
  },
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Justin Zarb",
    "email": "justin.zarb@zarb.co.uk"
  },
  "flow": {
    "triggers": [
      {
        "id": "presence_started",
        "title": {
          "en": "Someone got into the bed"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          }
        ]
      },
      {
        "id": "presence_stopped",
        "title": {
          "en": "The bed became empty"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          }
        ]
      },
      {
        "id": "sleep_stage_changed",
        "title": {
          "en": "Sleep stage changed"
        },
        "tokens": [
          {
            "name": "stage",
            "type": "string",
            "title": {
              "en": "Stage"
            },
            "example": "deep"
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "is_present",
        "title": {
          "en": "Someone !{{is|isn't}} in the bed"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          }
        ]
      },
      {
        "id": "side_is_on",
        "title": {
          "en": "The side !{{is|isn't}} on"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          }
        ]
      },
      {
        "id": "is_away",
        "title": {
          "en": "Away mode !{{is|isn't}} on"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "set_temperature",
        "title": {
          "en": "Set target temperature"
        },
        "titleFormatted": {
          "en": "Set target temperature to [[temperature]] °C"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          },
          {
            "name": "temperature",
            "type": "number",
            "min": 13,
            "max": 44,
            "step": 0.5,
            "label": {
              "en": "°C"
            }
          }
        ]
      },
      {
        "id": "turn_on",
        "title": {
          "en": "Turn the side on"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          }
        ]
      },
      {
        "id": "turn_off",
        "title": {
          "en": "Turn the side off"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          }
        ]
      },
      {
        "id": "snooze_alarm",
        "title": {
          "en": "Snooze the alarm"
        },
        "titleFormatted": {
          "en": "Snooze the alarm for [[minutes]] minutes"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          },
          {
            "name": "minutes",
            "type": "number",
            "min": 1,
            "max": 60,
            "step": 1,
            "label": {
              "en": "min"
            }
          }
        ]
      },
      {
        "id": "stop_alarm",
        "title": {
          "en": "Stop the alarm"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          }
        ]
      },
      {
        "id": "start_away",
        "title": {
          "en": "Start away mode"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          }
        ]
      },
      {
        "id": "stop_away",
        "title": {
          "en": "Stop away mode"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          }
        ]
      },
      {
        "id": "prime_pod",
        "title": {
          "en": "Prime the Pod"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          }
        ]
      },
      {
        "id": "set_one_off_alarm",
        "title": {
          "en": "Set a one-off alarm"
        },
        "titleFormatted": {
          "en": "Set a one-off alarm at [[time]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bed-side"
          },
          {
            "name": "time",
            "type": "time"
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "Eight Sleep Bed Side"
      },
      "class": "thermostat",
      "capabilities": [
        "onoff",
        "target_temperature",
        "measure_temperature",
        "measure_temperature.room",
        "alarm_presence",
        "measure_heart_rate",
        "measure_hrv",
        "measure_breath_rate",
        "sleep_stage",
        "sleep_fitness_score",
        "sleep_quality_score",
        "sleep_routine_score",
        "time_slept",
        "next_alarm",
        "away_mode",
        "alarm_water_low",
        "is_priming",
        "button.alarm_snooze",
        "button.alarm_stop",
        "button.prime"
      ],
      "capabilitiesOptions": {
        "onoff": {
          "title": {
            "en": "Side power"
          }
        },
        "button.prime": {
          "title": {
            "en": "Prime Pod"
          },
          "maintenanceAction": true
        },
        "button.alarm_snooze": {
          "title": {
            "en": "Snooze alarm"
          },
          "maintenanceAction": true
        },
        "button.alarm_stop": {
          "title": {
            "en": "Stop alarm"
          },
          "maintenanceAction": true
        },
        "target_temperature": {
          "title": {
            "en": "Target temperature"
          },
          "min": 13,
          "max": 44,
          "step": 0.5,
          "units": {
            "en": "°C"
          }
        },
        "measure_temperature": {
          "title": {
            "en": "Bed temperature"
          }
        },
        "measure_temperature.room": {
          "title": {
            "en": "Room temperature"
          }
        }
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "cloud"
      ],
      "images": {
        "small": "/drivers/bed-side/assets/images/small.png",
        "large": "/drivers/bed-side/assets/images/large.png",
        "xlarge": "/drivers/bed-side/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "login_credentials",
          "template": "login_credentials",
          "options": {
            "usernameLabel": {
              "en": "Email"
            },
            "usernamePlaceholder": "you@example.com",
            "passwordLabel": {
              "en": "Password"
            }
          },
          "navigation": {
            "next": "list_devices"
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "repair": [
        {
          "id": "login_credentials",
          "template": "login_credentials",
          "options": {
            "usernameLabel": {
              "en": "Email"
            },
            "usernamePlaceholder": "you@example.com",
            "passwordLabel": {
              "en": "Password"
            }
          }
        }
      ],
      "settings": [
        {
          "id": "poll_interval",
          "type": "number",
          "label": {
            "en": "Refresh interval (minutes)"
          },
          "value": 5,
          "min": 1,
          "max": 60,
          "hint": {
            "en": "How often to read the bed side's state from Eight Sleep."
          }
        }
      ],
      "id": "bed-side"
    }
  ],
  "widgets": {
    "bedside": {
      "name": {
        "en": "Eight Sleep"
      },
      "height": 240,
      "transparent": false,
      "api": {
        "getSides": {
          "method": "GET",
          "path": "/sides"
        },
        "getState": {
          "method": "GET",
          "path": "/state"
        },
        "setPower": {
          "method": "POST",
          "path": "/power"
        },
        "setTemperature": {
          "method": "POST",
          "path": "/temperature"
        }
      },
      "id": "bedside",
      "settings": []
    }
  },
  "capabilities": {
    "alarm_presence": {
      "type": "boolean",
      "title": {
        "en": "Bed presence"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true
    },
    "alarm_water_low": {
      "type": "boolean",
      "title": {
        "en": "Water low"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true
    },
    "away_mode": {
      "type": "boolean",
      "title": {
        "en": "Away mode"
      },
      "getable": true,
      "setable": true,
      "uiComponent": "toggle",
      "insights": true
    },
    "base_feet_angle": {
      "type": "number",
      "title": {
        "en": "Feet angle"
      },
      "units": {
        "en": "°"
      },
      "min": 0,
      "max": 45,
      "step": 1,
      "decimals": 0,
      "getable": true,
      "setable": true,
      "uiComponent": "slider",
      "insights": true
    },
    "base_head_angle": {
      "type": "number",
      "title": {
        "en": "Head angle"
      },
      "units": {
        "en": "°"
      },
      "min": 0,
      "max": 45,
      "step": 1,
      "decimals": 0,
      "getable": true,
      "setable": true,
      "uiComponent": "slider",
      "insights": true
    },
    "base_preset": {
      "type": "enum",
      "title": {
        "en": "Base preset"
      },
      "getable": true,
      "setable": true,
      "uiComponent": "picker",
      "values": [
        {
          "id": "sleep",
          "title": {
            "en": "Sleep"
          }
        },
        {
          "id": "relaxing",
          "title": {
            "en": "Relaxing"
          }
        },
        {
          "id": "reading",
          "title": {
            "en": "Reading"
          }
        },
        {
          "id": "flat",
          "title": {
            "en": "Flat"
          }
        }
      ]
    },
    "base_snore_mitigation": {
      "type": "boolean",
      "title": {
        "en": "Snore mitigation"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true
    },
    "is_priming": {
      "type": "boolean",
      "title": {
        "en": "Priming"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true
    },
    "measure_breath_rate": {
      "type": "number",
      "title": {
        "en": "Breath rate"
      },
      "units": {
        "en": "/min"
      },
      "decimals": 1,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true
    },
    "measure_heart_rate": {
      "type": "number",
      "title": {
        "en": "Heart rate"
      },
      "units": {
        "en": "bpm"
      },
      "decimals": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true
    },
    "measure_hrv": {
      "type": "number",
      "title": {
        "en": "Heart rate variability"
      },
      "units": {
        "en": "ms"
      },
      "decimals": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true
    },
    "next_alarm": {
      "type": "string",
      "title": {
        "en": "Next alarm"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false
    },
    "sleep_fitness_score": {
      "type": "number",
      "title": {
        "en": "Sleep fitness score"
      },
      "decimals": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true
    },
    "sleep_quality_score": {
      "type": "number",
      "title": {
        "en": "Sleep quality score"
      },
      "decimals": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true
    },
    "sleep_routine_score": {
      "type": "number",
      "title": {
        "en": "Sleep routine score"
      },
      "decimals": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true
    },
    "sleep_stage": {
      "type": "string",
      "title": {
        "en": "Sleep stage"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false
    },
    "time_slept": {
      "type": "number",
      "title": {
        "en": "Time slept"
      },
      "units": {
        "en": "h"
      },
      "decimals": 1,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true
    }
  }
}